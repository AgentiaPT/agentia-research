    <!-- Footer -->
    <footer style="text-align:center;padding:32px 0 48px;color:var(--muted);font-size:0.82rem;">
      <p>AI × Software Engineering Weekly — Edition: The Reality Check</p>
      <p style="margin-top:4px;">Built for <a href="https://github.com/AgentiaPT/agentia-research" style="color:var(--accent);text-decoration:none;">agentia-research</a></p>

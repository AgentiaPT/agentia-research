<body>
<div class="layout">
  <!-- Sidebar Navigation -->
  <nav class="sidebar">
    <a href="README.md" class="back-link">← Back to README</a>
    <h2>Sections</h2>
    <a href="#stats">📊 Key Numbers</a>
    <a href="#signals">📡 Signal Radar</a>
    <a href="#coverage">📈 Theme Coverage</a>
    <a href="#voicemap">🗺️ Voice Position Map</a>
    <a href="#quotes">💬 Key Quotes</a>
    <a href="#tracker">👥 Voice Tracker</a>
  </nav>

  <!-- Main Content -->
  <main class="main">
    <!-- Header -->
    <header class="header" id="top">
      <h1 class="gradient-text">The Reality Check</h1>
      <p class="subtitle">AI × Software Engineering — Weekly Intelligence Brief</p>
      <span class="date-badge">📅 April 17 – 24, 2026</span>
    </header>

    <!-- Stats Grid -->
    <section id="stats">
      <h2 class="section-title gradient-text">📊 Key Numbers This Week</h2>
      <div class="stats-grid">
        <div class="stat-card green">
          <div class="value">82.7%</div>
          <div class="label">GPT-5.5 TerminalBench</div>
        </div>
        <div class="stat-card green">
          <div class="value">64.3%</div>
          <div class="label">Opus 4.7 SWE-Bench Pro</div>
        </div>
        <div class="stat-card red">
          <div class="value">2×</div>
          <div class="label">GPT-5.5 Price vs GPT-5</div>
        </div>
        <div class="stat-card green">
          <div class="value">$0.14/M</div>
          <div class="label">DeepSeek V4 Input Tokens</div>
        </div>
        <div class="stat-card red">
          <div class="value">−27%</div>
          <div class="label">Software ETF (6-month)</div>
        </div>
        <div class="stat-card red">
          <div class="value">8,000</div>
          <div class="label">Meta Layoffs</div>
        </div>
        <div class="stat-card red">
          <div class="value">200K+</div>
          <div class="label">MCP Servers Exposed</div>
        </div>
        <div class="stat-card orange">
          <div class="value">$60B</div>
          <div class="label">SpaceX / Cursor Valuation</div>
        </div>
      </div>
    </section>

    <!-- Signal Radar -->
    <section id="signals">
      <div class="card">
        <h2 class="gradient-text">📡 Signal Radar</h2>

        <div class="signal-section">
          <div class="signal-header"><span style="font-size:1.2em">🔴</span> Critical</div>
          <ul class="signal-items">
            <li>MCP remote-code-execution "by design" — 200K+ servers exposed</li>
            <li>CanisterSprawl worm — first self-propagating AI supply-chain attack</li>
          </ul>
        </div>

        <div class="signal-section">
          <div class="signal-header"><span style="font-size:1.2em">🟠</span> Warning</div>
          <ul class="signal-items">
            <li>Software stock repricing — IGV ETF down 27% in six months</li>
            <li>Meta layoffs template — 8,000 cuts; "AI can do it" as justification</li>
            <li>GPT-5.5 pricing 2× predecessor — capability vs cost tension</li>
          </ul>
        </div>

        <div class="signal-section">
          <div class="signal-header"><span style="font-size:1.2em">🟢</span> Emerging</div>
          <ul class="signal-items">
            <li>DeepSeek V4 on Chinese silicon — domestic chip independence</li>
            <li>Claude Design threatens Figma — AI enters design tooling</li>
            <li>Anthropic transparency — Claude 4 system prompt published</li>
          </ul>
        </div>

        <div class="signal-section">
          <div class="signal-header"><span style="font-size:1.2em">🔵</span> Watch</div>
          <ul class="signal-items">
            <li>SpaceX / Cursor $60B valuation — AI-native editor premium</li>
            <li>ICLR safety papers — alignment research accelerating</li>
            <li>Mollick gaming thesis + $22B AI investment wave</li>
            <li>Comment and Control — adversarial code comments hijack agents</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Theme Coverage Bars -->
    <section id="coverage">
      <div class="card">
        <h2 class="gradient-text">📈 Theme Coverage</h2>
        <div class="bar-row">
          <span class="bar-label">§1 Narrative</span>
          <div class="bar-track"><div class="bar-fill" style="width:100%">100%</div></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">§2 GPT-5.5</span>
          <div class="bar-track"><div class="bar-fill" style="width:90%">90%</div></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">§3 Postmortem</span>
          <div class="bar-track"><div class="bar-fill" style="width:85%">85%</div></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">§4 Claude Platform</span>
          <div class="bar-track"><div class="bar-fill" style="width:80%">80%</div></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">§5 Security</span>
          <div class="bar-track"><div class="bar-fill" style="width:95%">95%</div></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">§6 SpaceX / Cursor</span>
          <div class="bar-track"><div class="bar-fill" style="width:70%">70%</div></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">§7 Market</span>
          <div class="bar-track"><div class="bar-fill" style="width:85%">85%</div></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">§8 DeepSeek / Research</span>
          <div class="bar-track"><div class="bar-fill" style="width:75%">75%</div></div>
        </div>
      </div>
    </section>

    <!-- Voice Position Map -->
    <section id="voicemap">
      <div class="card">
        <h2 class="gradient-text">🗺️ Voice Position Map</h2>
        <p style="color:var(--muted);font-size:0.85rem;margin-bottom:16px;">Hover over dots to see names. X = Cautious ↔ Accelerationist · Y = Individual ↔ Institutional</p>
        <div class="voice-map-container">
          <div class="voice-map-inner">
            <div class="crosshair-h"></div>
            <div class="crosshair-v"></div>
            <span class="axis-label left">Individual</span>
            <span class="axis-label right">Institutional</span>
            <span class="axis-label top" style="top:4px">Institutional</span>
            <span class="axis-label bottom" style="bottom:4px">Individual</span>
            <span class="axis-label" style="left:8px;bottom:8px;font-size:10px;">Cautious</span>
            <span class="axis-label" style="right:8px;bottom:8px;font-size:10px;">Accelerationist</span>

            <!-- Voices plotted: x% from left, (100-y)% from top -->
            <div class="voice-dot" style="left:35%;top:15%;background:var(--purple);">
              <span class="tooltip">Dario Amodei — Cautious / Institutional</span>
            </div>
            <div class="voice-dot" style="left:75%;top:10%;background:var(--red);">
              <span class="tooltip">Sam Altman — Accelerationist / Institutional</span>
            </div>
            <div class="voice-dot" style="left:55%;top:40%;background:var(--orange);">
              <span class="tooltip">Ethan Mollick — Center / Academic</span>
            </div>
            <div class="voice-dot" style="left:70%;top:20%;background:var(--accent);">
              <span class="tooltip">Aaron Levie — Accelerationist / Institutional</span>
            </div>
            <div class="voice-dot" style="left:60%;top:50%;background:var(--green);">
              <span class="tooltip">Steve Yegge — Center / Individual</span>
            </div>
            <div class="voice-dot" style="left:40%;top:45%;background:var(--yellow);">
              <span class="tooltip">Martin Fowler — Cautious / Individual</span>
            </div>
            <div class="voice-dot" style="left:30%;top:55%;background:var(--red);">
              <span class="tooltip">DHH — Cautious / Individual</span>
            </div>
            <div class="voice-dot" style="left:45%;top:60%;background:var(--muted);">
              <span class="tooltip">Daniel Stenberg — Center / Individual</span>
            </div>
            <div class="voice-dot" style="left:55%;top:55%;background:var(--green);">
              <span class="tooltip">Simon Willison — Center / Individual</span>
            </div>
            <div class="voice-dot" style="left:65%;top:25%;background:var(--accent);">
              <span class="tooltip">Guillermo Rauch — Accelerationist / Institutional</span>
            </div>
            <div class="voice-dot" style="left:65%;top:50%;background:var(--orange);">
              <span class="tooltip">Swyx — Accelerationist / Individual</span>
            </div>
            <div class="voice-dot" style="left:50%;top:45%;background:var(--green);">
              <span class="tooltip">Gergely Orosz — Center / Individual</span>
            </div>
          </div>
        </div>
      </div>
    </section>
